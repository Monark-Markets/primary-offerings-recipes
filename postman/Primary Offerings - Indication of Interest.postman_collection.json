									"});",
									"",
									"console.log('Accreditation status updated');"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"investorId\": \"{{investorId}}\",\n\t\"accreditationStatus\": \"KNOWLEDGEABLE_EMPLOYEE\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/primary/v1/investor/accreditation",
							"host": ["{{baseUrl}}"],
							"path": ["primary", "v1", "investor", "accreditation"]
						},
						"description": "Update investor accreditation status."
					},
					"response": []
				},
				{
					"name": "1.6 Create Financial Advisor",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"if (!pm.collectionVariables.get('financialInstitutionId')) {",
									"    throw new Error('financialInstitutionId is required.');",
									"}",
									"",
									"// Generate random CRD and IARD numbers",
									"const randomDigits = (len) => {",
									"    let str = '';",
									"    for (let i = 0; i < len; i++) {",
									"        str += Math.floor(Math.random() * 10);",
									"    }",
									"    return str;",
									"};",
									"",
									"pm.collectionVariables.set('crdNumber', randomDigits(8));",
									"pm.collectionVariables.set('iardNumber', randomDigits(8));"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 201', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"if (response && response.id) {",
									"    pm.collectionVariables.set('financialAdvisorId', response.id);",
									"    console.log('Financial Advisor ID:', response.id);",
									"} else {",
									"    console.error('No financial advisor ID in response');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"financialInstitutionId\": \"{{financialInstitutionId}}\",\n\t\"crdNumber\": \"{{crdNumber}}\",\n\t\"iardNumber\": \"{{iardNumber}}\",\n\t\"firstName\": \"Jane\",\n\t\"lastName\": \"Advisor\",\n\t\"mailingAddress\": \"123 Main St\",\n\t\"mailingCity\": \"New York\",\n\t\"mailingState\": \"NY\",\n\t\"mailingZipCode\": \"10001\",\n\t\"mailingCountryCode\": \"US\",\n\t\"branchNumber\": \"001\",\n\t\"phoneCountryCode\": \"1\",\n\t\"phoneNumber\": \"1234567890\",\n\t\"phoneExtension\": \"123\",\n\t\"emailAddress\": \"johnadvisor@example.com\",\n\t\"fax\": \"123-456-7890\",\n\t\"prefix\": \"Mrs\",\n\t\"broker\": \"ExampleBroker\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/primary/v1/financial-advisor",
							"host": ["{{baseUrl}}"],
							"path": ["primary", "v1", "financial-advisor"]
						},
						"description": "Create a financial advisor for the investor."
					},
					"response": []
				},
				{
					"name": "1.7 Update Investor Details",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"if (!pm.collectionVariables.get('investorId')) {",
									"    throw new Error('investorId is required.');",
									"}",
									"if (!pm.collectionVariables.get('investorReferenceId')) {",
									"    throw new Error('investorReferenceId is required.');",
									"}",
									"if (!pm.collectionVariables.get('financialAdvisorId')) {",
									"    throw new Error('financialAdvisorId is required. Run \"Create Financial Advisor\" first.');",
									"}"
