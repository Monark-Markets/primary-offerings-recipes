{
	"info": {
		"_postman_id": "primary-offerings-ioi-collection",
		"name": "Primary Offerings - Indication of Interest",
		"description": "Postman collection for submitting Indications of Interest (IOI) through the Primary Offerings V2 API.\n\n**Sections:**\n1. Investor Onboarding (Get Financial Institutions, Get/Create Investor, Create Financial Advisor)\n2. Submit PreIPOCompany IOI (Get PreIPO Companies, Create IOI for Company)\n3. Submit RegisteredFund IOI (Get Registered Funds, Create IOI for Fund)\n\nThe V2 API supports multiple asset types using `targetId` and `targetAssetType` fields:\n- PreIPOCompany\n- RegisteredFund\n\n**Setup:**\n1. Import the environment file: Primary Offerings - Indication of Interest.postman_environment.json\n2. Set `baseUrl` and `apiKey` in the environment\n3. Run manually (click Send on each request) OR use Collection Runner (Ctrl/Cmd+R)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{apiKey}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Clear collection variables at the start of each run",
					"if (pm.info.requestName === '1.1 Get All Financial Institutions') {",
					"    const variablesToClear = [",
					"        'financialInstitutionId',",
					"        'investorId',",
					"        'investorName',",
					"        'financialAdvisorId',",
					"        'allPreIPOCompanies',",
					"        'selectedPreIPOCompanyId',",
					"        'selectedPreIPOCompanyName',",
					"        'allRegisteredFunds',",
					"        'selectedRegisteredFundId',",
					"        'selectedRegisteredFundName',",
					"        'ioiId',",
					"        'numberOfClients'",
					"    ];",
					"    ",
					"    variablesToClear.forEach(varName => {",
					"        pm.collectionVariables.unset(varName);",
					"    });",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Check if this is the last request in either IOI workflow",
					"const isCompanyIOIComplete = pm.info.requestName === '2. Create IOI for PreIPO Company';",
					"const isRegisteredFundIOIComplete = pm.info.requestName === '2. Create IOI for Registered Fund';",
					"",
					"if (isCompanyIOIComplete) {",
					"    console.log('');",
					"    console.log('='.repeat(70));",
					"    console.log('PRE-IPO COMPANY IOI SUBMISSION COMPLETED (V2 API)');",
					"    console.log('='.repeat(70));",
					"    console.log('Investor ID:', pm.collectionVariables.get('investorId'));",
					"    console.log('Investor Name:', pm.collectionVariables.get('investorName'));",
					"    console.log('Target Company:', pm.collectionVariables.get('selectedPreIPOCompanyName'));",
					"    console.log('Target Asset Type: PreIPOCompany');",
					"    console.log('Notional Amount:', pm.collectionVariables.get('ioiNotionalAmount'));",
					"    console.log('IOI ID:', pm.collectionVariables.get('ioiId'));",
					"    console.log('='.repeat(70));",
					"} else if (isRegisteredFundIOIComplete) {",
					"    console.log('');",
					"    console.log('='.repeat(70));",
					"    console.log('REGISTERED FUND IOI SUBMISSION COMPLETED (V2 API)');",
					"    console.log('='.repeat(70));",
					"    console.log('Investor ID:', pm.collectionVariables.get('investorId'));",
					"    console.log('Investor Name:', pm.collectionVariables.get('investorName'));",
					"    console.log('Target Fund:', pm.collectionVariables.get('selectedRegisteredFundName'));",
					"    console.log('Target Asset Type: RegisteredFund');",
					"    console.log('Notional Amount:', pm.collectionVariables.get('ioiNotionalAmount'));",
					"    console.log('IOI ID:', pm.collectionVariables.get('ioiId'));",
					"    console.log('='.repeat(70));",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "1. Investor Onboarding",
			"item": [
				{
					"name": "1.1 Get All Financial Institutions",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"if (response && response.items && response.items.length > 0) {",
									"    // Find default financial institution",
									"    const defaultFI = response.items.find(fi => fi.isDefault === true);",
									"    ",
									"    if (defaultFI) {",
									"        pm.collectionVariables.set('financialInstitutionId', defaultFI.id);",
									"        console.log('Financial Institution ID:', defaultFI.id);",
									"    } else {",
									"        console.error('No default financial institution found');",
									"    }",
									"} else {",
									"    console.error('No financial institutions returned');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/primary/v1/financial-institution?page=1&pageSize=100",
							"host": ["{{baseUrl}}"],
							"path": ["primary", "v1", "financial-institution"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "pageSize",
									"value": "100"
								}
							]
						},
						"description": "Fetch all financial institutions and select the one."
					},
					"response": []
				},
				{
					"name": "1.2 Create Investor",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"if (!pm.collectionVariables.get('financialInstitutionId')) {",
									"    throw new Error('financialInstitutionId is required. Run \"Get All Financial Institutions\" first.');",
									"}",
									"",
									"// Generate random investor reference ID",
									"const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';",
									"let randomStr = '';",
									"for (let i = 0; i < 20; i++) {",
									"    randomStr += chars.charAt(Math.floor(Math.random() * chars.length));",
									"}",
									"pm.collectionVariables.set('investorReferenceId', 'Investor-' + randomStr);"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 201', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"if (response && response.id) {",
									"    pm.collectionVariables.set('investorId', response.id);",
									"    console.log('Investor ID:', response.id);",
									"} else {",
									"    console.error('No investor ID in response');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"investorReferenceId\": \"{{investorReferenceId}}\",\n\t\"financialInstitutionId\": \"{{financialInstitutionId}}\",\n\t\"type\": \"IndividualInvestor\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/primary/v1/investor",
							"host": ["{{baseUrl}}"],
							"path": ["primary", "v1", "investor"]
						},
						"description": "Create a new investor with Pending status."
					},
					"response": []
				},
				{
					"name": "1.3 Get All Questionnaires",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"if (response && response.items && response.items.length > 0) {",
									"    pm.collectionVariables.set('questionnaires', JSON.stringify(response.items));",
									"    console.log('Questionnaires count:', response.items.length);",
									"} else {",
									"    console.log('No questionnaires found');",
									"    pm.collectionVariables.set('questionnaires', JSON.stringify([]));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/primary/v1/questionnaire",
							"host": ["{{baseUrl}}"],
							"path": ["primary", "v1", "questionnaire"]
						},
						"description": "Fetch all available questionnaires."
					},
					"response": []
				},
				{
					"name": "1.4 Answer Questionnaires",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"if (!pm.collectionVariables.get('investorId')) {",
									"    throw new Error('investorId is required. Run \"Create Investor\" first.');",
									"}",
									"",
									"if (!pm.collectionVariables.get('questionnaires')) {",
									"    throw new Error('questionnaires are required. Run \"Get All Questionnaires\" first.');",
									"}",
									"",
									"// Note: This is a sample request. You'll need to run this for each questionnaire.",
									"// In automation, you'd loop through questionnaires and answer each one.",
									"const questionnaires = JSON.parse(pm.collectionVariables.get('questionnaires'));",
									"",
									"if (questionnaires.length === 0) {",
									"    console.log('No questionnaires to answer');",
									"    return;",
									"}",
									"",
									"// Take the first questionnaire as an example",
									"const questionnaire = questionnaires[0];",
									"pm.collectionVariables.set('currentQuestionnaireId', questionnaire.id);",
									"",
									"// Generate random answers for questions",
									"const answers = [];",
									"if (questionnaire.questions) {",
									"    questionnaire.questions.forEach(q => {",
									"        let value;",
									"        if (q.options && q.options.length > 0) {",
									"            value = q.options[Math.floor(Math.random() * q.options.length)];",
									"        } else {",
									"            switch (q.format) {",
									"                case 'INTEGER':",
									"                    value = String(Math.floor(Math.random() * 20));",
									"                    break;",
									"                case 'BOOLEAN':",
									"                    value = String(Math.random() > 0.5);",
									"                    break;",
									"                default:",
									"                    value = String(Math.floor(Math.random() * 2));",
									"            }",
									"        }",
									"        answers.push({",
									"            questionnaireQuestionId: q.id,",
									"            value: value",
									"        });",
									"    });",
									"}",
									"",
									"pm.collectionVariables.set('questionnaireAnswers', JSON.stringify(answers));"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 201', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
									"});",
									"",
									"console.log('Questionnaire answered successfully');"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"questionnaireId\": \"{{currentQuestionnaireId}}\",\n\t\"investorId\": \"{{investorId}}\",\n\t\"createQuestionAnswers\": {{questionnaireAnswers}}\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/primary/v1/questionnaire-answer",
							"host": ["{{baseUrl}}"],
							"path": ["primary", "v1", "questionnaire-answer"]
						},
						"description": "Submit answers to questionnaire questions. Note: Run this for each questionnaire if multiple exist."
					},
					"response": []
				},
				{
					"name": "1.5 Update Investor Accreditation",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"if (!pm.collectionVariables.get('investorId')) {",
									"    throw new Error('investorId is required. Run \"Create Investor\" first.');",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
