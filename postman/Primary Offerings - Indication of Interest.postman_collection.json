		{
			"name": "2. Submit PreIPOCompany IOI",
			"item": [
				{
					"name": "1. Get All PreIPO Companies",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// No prerequisites - this endpoint is public"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const response = pm.response.json();",
									"",
									"if (response && response.items && response.items.length > 0) {",
									"    // Store all companies",
									"    pm.collectionVariables.set('allPreIPOCompanies', JSON.stringify(response.items));",
									"    ",
									"    console.log('='.repeat(50));",
									"    console.log('AVAILABLE PRE-IPO COMPANIES');",
									"    console.log('='.repeat(50));",
									"    console.log(`Total Companies: ${response.items.length}`);",
									"    console.log('');",
									"    ",
									"    response.items.forEach((company, index) => {",
									"        console.log(`[${index + 1}] ${company.name}`);",
									"        console.log(`    ID: ${company.id}`);",
									"        console.log(`    Symbol: ${company.symbol || 'N/A'}`);",
									"        console.log(`    Industry: ${company.industry || 'N/A'}`);",
									"        if (company.lastValuation) {",
									"            console.log(`    Last Valuation: $${company.lastValuation.toLocaleString()}`);",
									"        }",
									"        console.log('');",
									"    });",
									"    ",
									"    // Auto-select the first company for convenience",
									"    if (response.items[0]) {",
									"        pm.collectionVariables.set('selectedPreIPOCompanyId', response.items[0].id);",
